        local entry={btn=btn,bar=abar,lbl=lbl,icon=ilbl,page=page}

        local function Activate()
            for _,e in ipairs(W._tabs) do
                Tween(e.btn,{BackgroundTransparency=1},0.18); Tween(e.bar,{BackgroundTransparency=1},0.18)
                Tween(e.lbl,{TextColor3=T.TextDim},0.18); Tween(e.icon,{TextColor3=T.TextDim},0.18)
