-- ============================================================
local NotificationHolder = nil -- created lazily when Window is built

local function CreateNotificationSystem(screenGui)
	-- Container pinned to top-right
	local holder = Instance.new("Frame")
	holder.Name = "NotificationHolder"
	holder.BackgroundTransparency = 1
	holder.AnchorPoint = Vector2.new(1, 0)
	holder.Position = UDim2.new(1, -12, 0, 12)
	holder.Size = UDim2.new(0, 280, 1, -24)
	holder.ClipsDescendants = false
	holder.ZIndex = 99999

	local layout = Instance.new("UIListLayout")
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.VerticalAlignment = Enum.VerticalAlignment.Top
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Right
	layout.Padding = UDim.new(0, 6)
	layout.Parent = holder
	holder.Parent = screenGui

	return holder
end

local _notifOrder = 0

local function FireNotification(screenGui, cfg)
	cfg = cfg or {}
	local title    = cfg.Title       or "Notification"
	local content  = cfg.Content     or ""
	local icon     = cfg.Icon        or ""
	local duration = cfg.Duration    or 5

	if not NotificationHolder then
		NotificationHolder = CreateNotificationSystem(screenGui)
	end

	_notifOrder += 1

	-- Outer frame (for layout)
	local notifFrame = Instance.new("Frame")
	notifFrame.Name = "Notification"
	notifFrame.BackgroundTransparency = 1
	notifFrame.Size = UDim2.new(1, 0, 0, 70)
	notifFrame.AutomaticSize = Enum.AutomaticSize.Y
	notifFrame.LayoutOrder = _notifOrder
	notifFrame.ClipsDescendants = false
	notifFrame.Parent = NotificationHolder

	-- Card background
	local card = Instance.new("Frame")
	card.Name = "Card"
	card.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
	card.BackgroundTransparency = 0.05
	card.BorderSizePixel = 0
	card.Size = UDim2.new(1, 0, 0, 64)
	card.AutomaticSize = Enum.AutomaticSize.Y
	card.Position = UDim2.new(1.1, 0, 0, 0) -- starts off-screen right
	card.ClipsDescendants = true
	card.Parent = notifFrame

	local cardCorner = Instance.new("UICorner")
	cardCorner.CornerRadius = UDim.new(0, 8)
	cardCorner.Parent = card

	local cardStroke = Instance.new("UIStroke")
	cardStroke.Color = Color3.fromRGB(55, 55, 55)
	cardStroke.Thickness = 1
	cardStroke.Parent = card

	-- Accent bar (left side)
	local accent = Instance.new("Frame")
	accent.Name = "Accent"
	accent.BackgroundColor3 = Color3.fromRGB(93, 197, 248)
	accent.BorderSizePixel = 0
	accent.Size = UDim2.new(0, 3, 1, 0)
	accent.Position = UDim2.new(0, 0, 0, 0)
	accent.Parent = card

	local accentCorner = Instance.new("UICorner")
	accentCorner.CornerRadius = UDim.new(0, 4)
	accentCorner.Parent = accent

	-- Icon (only shown if icon provided)
	local hasIcon = icon ~= nil and icon ~= ""
	local iconLabel = Instance.new("ImageLabel")
	iconLabel.Name = "Icon"
	iconLabel.BackgroundTransparency = 1
	iconLabel.Size = UDim2.new(0, 22, 0, 22)
	iconLabel.AnchorPoint = Vector2.new(0, 0.5)
	iconLabel.Position = UDim2.new(0, hasIcon and 14 or 0, 0.5, 0)
	iconLabel.Image = icon
	iconLabel.ImageColor3 = Color3.fromRGB(200, 200, 200)
	iconLabel.Visible = hasIcon
	iconLabel.Parent = card

	local textOffsetX = hasIcon and 44 or 14

	-- Title
	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.BackgroundTransparency = 1
	titleLabel.Position = UDim2.new(0, textOffsetX, 0, 10)
	titleLabel.Size = UDim2.new(1, -(textOffsetX + 10), 0, 16)
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.Text = title
	titleLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
	titleLabel.TextSize = 13
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextTruncate = Enum.TextTruncate.AtEnd
	titleLabel.Parent = card

	-- Content
	local contentLabel = Instance.new("TextLabel")
	contentLabel.Name = "Content"
	contentLabel.BackgroundTransparency = 1
	contentLabel.Position = UDim2.new(0, textOffsetX, 0, 28)
	contentLabel.Size = UDim2.new(1, -(textOffsetX + 10), 0, 24)
	contentLabel.Font = Enum.Font.GothamMedium
	contentLabel.Text = content
	contentLabel.TextColor3 = Color3.fromRGB(170, 170, 170)
	contentLabel.TextSize = 11
	contentLabel.TextXAlignment = Enum.TextXAlignment.Left
	contentLabel.TextWrapped = true
	contentLabel.Parent = card

	-- Timer bar (bottom progress)
	local timerBg = Instance.new("Frame")
	timerBg.Name = "TimerBg"
	timerBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
	timerBg.BorderSizePixel = 0
	timerBg.AnchorPoint = Vector2.new(0, 1)
	timerBg.Position = UDim2.new(0, 0, 1, 0)
	timerBg.Size = UDim2.new(1, 0, 0, 3)
	timerBg.Parent = card

	local timerBar = Instance.new("Frame")
	timerBar.Name = "TimerBar"
	timerBar.BackgroundColor3 = Color3.fromRGB(93, 197, 248)
	timerBar.BorderSizePixel = 0
	timerBar.Size = UDim2.new(1, 0, 1, 0)
	timerBar.Parent = timerBg

	local timerCorner = Instance.new("UICorner")
	timerCorner.CornerRadius = UDim.new(0, 3)
	timerCorner.Parent = timerBg

	-- Slide in
	local slideIn = obj.TweenService:Create(card, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {
		Position = UDim2.new(0, 0, 0, 0)
	})
	slideIn:Play()

	-- Timer countdown tween
	local timerTween = obj.TweenService:Create(timerBar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
		Size = UDim2.new(0, 0, 1, 0)
	})
	timerTween:Play()

	-- Close logic
	local closed = false
	local function CloseNotif()
		if closed then return end
		closed = true
		timerTween:Cancel()
		local slideOut = obj.TweenService:Create(card, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {
			Position = UDim2.new(1.1, 0, 0, 0)
		})
		slideOut:Play()
		slideOut.Completed:Connect(function()
			notifFrame:Destroy()
		end)
	end

	-- Click to dismiss
	local clickBtn = Instance.new("TextButton")
	clickBtn.BackgroundTransparency = 1
	clickBtn.Size = UDim2.new(1, 0, 1, 0)
	clickBtn.Text = ""
	clickBtn.ZIndex = card.ZIndex + 1
	clickBtn.Parent = card
	clickBtn.MouseButton1Click:Connect(CloseNotif)

	-- Auto-close after duration
	task.delay(duration, CloseNotif)

	return {
		Close = CloseNotif,
		SetTitle = function(t) titleLabel.Text = t end,
		SetContent = function(c) contentLabel.Text = c end,
	}
end

