                Corner(7,pill); Stroke(T.Border,1,0.2,pill)
                local ps=New("Frame",{BackgroundColor3=T.GlassLight,BackgroundTransparency=0.82,BorderSizePixel=0,
                    Position=UDim2.new(0,4,0,0),Size=UDim2.new(1,-8,0,1),ZIndex=16,Parent=pill})
                Corner(1,ps)
                pill.MouseEnter:Connect(function()
                    Tween(pill,{BackgroundColor3=T.Accent,BackgroundTransparency=0.1,TextColor3=Color3.fromRGB(255,255,255)},0.18)
                    local st=pill:FindFirstChildWhichIsA("UIStroke"); if st then Tween(st,{Color=T.AccentGlow},0.18) end
                end)
                pill.MouseLeave:Connect(function()
                    Tween(pill,{BackgroundColor3=T.SurfaceTop,BackgroundTransparency=0.2,TextColor3=T.TextMuted},0.18)
                    local st=pill:FindFirstChildWhichIsA("UIStroke"); if st then Tween(st,{Color=T.Border},0.18) end
                end)
                pill.MouseButton1Click:Connect(function()
                    Tween(pill,{BackgroundColor3=T.AccentDark},0.08)
                    task.delay(0.14,function() Tween(pill,{BackgroundColor3=T.SurfaceTop},0.2) end)
                    cb()
                end)
                return pill
            end

            -- SLIDER
            function S:AddSlider(c)
                c=c or {}
                local mn=c.Min or 0; local mx=c.Max or 100; local def=c.Default or mn
                local inc=c.Increment or 1; local cb=c.Callback or function() end
                local r=Row(54); Labels(r,c.Title or "Slider",c.Description or "")
                local vl=New("TextLabel",{AnchorPoint=Vector2.new(1,0),BackgroundTransparency=1,
                    Position=UDim2.new(1,-12,0,8),Size=UDim2.new(0,50,0,14),Font=Enum.Font.GothamBold,
                    Text=tostring(def),TextColor3=T.AccentBright,TextSize=12,
                    TextXAlignment=Enum.TextXAlignment.Right,ZIndex=15,Parent=r})
                local tbg=New("Frame",{BackgroundColor3=T.SurfaceTop,BorderSizePixel=0,
                    Position=UDim2.new(0,12,1,-14),Size=UDim2.new(1,-24,0,5),ZIndex=15,Parent=r})
                Corner(4,tbg)
                local fill=New("Frame",{BackgroundColor3=T.Accent,BorderSizePixel=0,
                    Size=UDim2.new(0,0,1,0),ZIndex=16,Parent=tbg})
                Corner(4,fill); New("UIGradient",{Color=ColorSequence.new(T.AccentGlow,T.Accent),Parent=fill})
                local handle=New("Frame",{AnchorPoint=Vector2.new(0.5,0.5),BackgroundColor3=Color3.fromRGB(255,255,255),
                    BorderSizePixel=0,Position=UDim2.new(0,0,0.5,0),Size=UDim2.new(0,13,0,13),ZIndex=17,Parent=tbg})
                Corner(100,handle); Stroke(T.Accent,2,0,handle)
                local cur=def
                local function SetVal(v,silent)
                    v=math.clamp(math.round(v/inc)*inc,mn,mx); cur=v
                    local p=(v-mn)/(mx-mn)
                    Tween(fill,{Size=UDim2.new(p,0,1,0)},0.1); Tween(handle,{Position=UDim2.new(p,0,0.5,0)},0.1)
                    vl.Text=tostring(v); if not silent then cb(v) end
                end
                SetVal(def,true)
                local sliding=false
                New("TextButton",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text="",ZIndex=18,Parent=tbg})
                    .MouseButton1Down:Connect(function() sliding=true end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end
                end)
                local conn; conn=RS.RenderStepped:Connect(function()
                    if sliding then
                        local ap=tbg.AbsolutePosition; local as=tbg.AbsoluteSize
                        local ml=UIS:GetMouseLocation()
                        SetVal(mn+(mx-mn)*math.clamp((ml.X-ap.X)/as.X,0,1))
                    end
                end)
                tbg.AncestryChanged:Connect(function()
                    if not tbg:IsDescendantOf(game) then conn:Disconnect() end
                end)
                return {Set=SetVal,Get=function() return cur end}
            end

            -- DROPDOWN
            function S:AddDropdown(c)
                c=c or {}
                local vals=c.Values or {}; local def=c.Default or {}
                local multi=c.Multi or false; local cb=c.Callback or function() end
                if type(def)=="string" then def={def} end
                local sel={}; for _,v in ipairs(def) do sel[v]=true end
                local r=Row(46); Labels(r,c.Title or "Dropdown",c.Description or "")
                local function ST()
                    local k={}; for v in pairs(sel) do table.insert(k,v) end
                    if #k==0 then return "None" elseif #k==1 then return k[1]
                    else return k[1].." +"..#k-1 end
                end
                local db=New("TextButton",{AnchorPoint=Vector2.new(1,0.5),BackgroundColor3=T.SurfaceTop,
                    BackgroundTransparency=0.2,BorderSizePixel=0,Position=UDim2.new(1,-12,0.5,0),
                    Size=UDim2.new(0,116,0,26),Font=Enum.Font.Gotham,Text=ST(),TextColor3=T.TextMuted,
                    TextSize=11,AutoButtonColor=false,ClipsDescendants=true,ZIndex=15,Parent=r})
                Corner(7,db); Stroke(T.Border,1,0.2,db); Pad(0,18,0,8,db)
                New("TextLabel",{AnchorPoint=Vector2.new(1,0.5),BackgroundTransparency=1,
                    Position=UDim2.new(1,-5,0.5,0),Size=UDim2.new(0,14,0,14),Font=Enum.Font.GothamBold,
                    Text="v",TextColor3=T.TextDim,TextSize=11,ZIndex=16,Parent=db})
                local open=false; local panel
                local function CP()
                    if panel then Tween(panel,{BackgroundTransparency=1},0.14)
                        task.delay(0.16,function() if panel then panel:Destroy(); panel=nil end end) end
                    open=false
                end
                local function OP()
                    if panel then CP(); return end; open=true
                    local ph=math.min(#vals*26+8,150)
                    panel=New("Frame",{BackgroundColor3=T.Surface,BackgroundTransparency=0.08,
                        BorderSizePixel=0,Position=UDim2.new(1,-128,0,r.Size.Y.Offset+2),
                        Size=UDim2.new(0,116,0,ph),ZIndex=50,Parent=sec})
                    Corner(8,panel); Stroke(T.Accent,1,0.5,panel); Shadow(panel,16,0.6); Noise(panel,0.94)
                    local ps=New("ScrollingFrame",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),
                        CanvasSize=UDim2.new(0,0,0,#vals*26+8),ScrollBarThickness=2,
                        ScrollBarImageColor3=T.Accent,ZIndex=51,Parent=panel})
                    Pad(4,4,4,4,ps); List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Left,2,ps)
                    for _,val in ipairs(vals) do
                        local isSel=sel[val]==true
                        local item=New("TextButton",{BackgroundColor3=isSel and T.Accent or T.SurfaceHigh,
                            BackgroundTransparency=isSel and 0.6 or 0,BorderSizePixel=0,
                            Size=UDim2.new(1,0,0,22),Font=Enum.Font.Gotham,Text=val,
                            TextColor3=isSel and T.AccentBright or T.TextMuted,TextSize=11,
                            AutoButtonColor=false,ZIndex=52,Parent=ps})
                        Corner(5,item)
                        item.MouseEnter:Connect(function()
                            if not sel[val] then Tween(item,{BackgroundTransparency=0.8,TextColor3=T.Text},0.1) end
                        end)
                        item.MouseLeave:Connect(function()
                            if not sel[val] then Tween(item,{BackgroundTransparency=0,TextColor3=T.TextMuted},0.1) end
                        end)
                        item.MouseButton1Click:Connect(function()
                            if multi then if sel[val] then sel[val]=nil else sel[val]=true end
                            else sel={}; sel[val]=true; CP() end
                            db.Text=ST()
                            local k={}; for v in pairs(sel) do table.insert(k,v) end
                            cb(multi and k or k[1])
                        end)
                    end
                    panel.BackgroundTransparency=1; Tween(panel,{BackgroundTransparency=0.08},0.15)
                end
                db.MouseButton1Click:Connect(OP)
                UIS.InputBegan:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1 and open and panel then
                        local ml=UIS:GetMouseLocation(); local ap=panel.AbsolutePosition; local as=panel.AbsoluteSize
                        if not(ml.X>=ap.X and ml.X<=ap.X+as.X and ml.Y>=ap.Y and ml.Y<=ap.Y+as.Y) then CP() end
                    end
                end)
                return {
                    Set=function(_,v)
                        sel={}
                        if type(v)=="table" then for _,x in ipairs(v) do sel[x]=true end else sel[v]=true end
                        db.Text=ST()
                    end,
                    Get=function() local k={}; for v in pairs(sel) do table.insert(k,v) end; return multi and k or k[1] end,
                }
            end

