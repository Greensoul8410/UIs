                List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Left,3,r)
                I("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,11),
                    Font=Enum.Font.GothamBold,Text=c.Title or "Info",
                    TextColor3=C.TextDim,TextSize=10,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=r})
                local cl=I("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),
                    AutomaticSize=Enum.AutomaticSize.Y,Font=Enum.Font.Gotham,
                    Text=c.Content or "",TextColor3=C.Text,TextSize=12,
                    TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,
                    RichText=true,ZIndex=5,Parent=r})
                return {SetContent=function(_,s) cl.Text=s end,
                        SetDescription=function(_,s) cl.Text=s end}
            end

            -- INPUT
            function S:AddInput(c)
                c=c or {}; local cb=c.Callback or function() end
                local r=Row(54); Labels(r,c.Title or "Input",c.Description or "")
                local box=I("TextBox",{AnchorPoint=Vector2.new(0.5,1),
                    BackgroundColor3=Color3.fromRGB(45,45,45),BackgroundTransparency=0.2,
                    BorderSizePixel=0,Position=UDim2.new(0.5,0,1,-7),
                    Size=UDim2.new(1,-24,0,22),Font=Enum.Font.Gotham,
                    PlaceholderColor3=C.TextDim,
                    PlaceholderText=c.Placeholder or "Type here...",
                    Text="",TextColor3=C.Text,TextSize=11,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    ClearTextOnFocus=false,ZIndex=5,Parent=r})
                Corner(5,box)
                local bs=Stroke(Color3.fromRGB(70,70,70),1,0.3,box)
                Pad(0,6,0,8,box)
                box.Focused:Connect(function()
                    TW(bs,{Color=C.Accent},0.15)
                    TW(box,{BackgroundTransparency=0},0.15)
                end)
                box.FocusLost:Connect(function(enter)
                    TW(bs,{Color=Color3.fromRGB(70,70,70)},0.15)
                    TW(box,{BackgroundTransparency=0.2},0.15)
                    cb(box.Text,enter)
                end)
                return box
            end

            -- DISCORD INVITE
            function S:AddDiscordInvite(c)
                c=c or {}
                local db=Color3.fromRGB(88,101,242)
                local card=I("Frame",{BackgroundColor3=db,BackgroundTransparency=0.12,
                    BorderSizePixel=0,Size=UDim2.new(1,0,0,58),ZIndex=4,Parent=items})
                Corner(8,card)
                Stroke(Color3.fromRGB(110,120,255),1,0.5,card)
                I("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,12,0,9),
                    Size=UDim2.new(0.72,0,0,16),Font=Enum.Font.GothamBold,
                    Text="# "..(c.Title or "Discord"),
                    TextColor3=Color3.fromRGB(255,255,255),TextSize=13,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=card})
                I("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,12,0,27),
                    Size=UDim2.new(0.72,0,0,12),Font=Enum.Font.Gotham,
                    Text=c.Description or "Join the server",
                    TextColor3=Color3.fromRGB(200,200,235),TextSize=10,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=card})
                local jb=I("TextButton",{AnchorPoint=Vector2.new(1,0.5),
                    BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,
                    Position=UDim2.new(1,-10,0.5,0),Size=UDim2.new(0,60,0,26),
                    Font=Enum.Font.GothamBold,Text="Join",TextColor3=db,TextSize=12,
                    AutoButtonColor=false,ZIndex=5,Parent=card})
                Corner(6,jb)
                jb.MouseEnter:Connect(function() TW(jb,{BackgroundTransparency=0.15},0.1) end)
                jb.MouseLeave:Connect(function() TW(jb,{BackgroundTransparency=0},0.1) end)
                jb.MouseButton1Click:Connect(function()
                    if (c.Link or "")~="" then
                        pcall(function() setclipboard(c.Link) end)
                    end
                    if c.Callback then c.Callback() end
                end)
            end

            return S
        end -- AddSection
        return TabObj
    end -- AddTab

    -- welcome notification
    task.delay(0.8,function()
        Notify({Title="NexusUI v3",
            Description="Welcome back, "..LP.DisplayName.."!",
            Duration=3,Type="success"})
    end)

    return W
end -- Window

return Nexus
