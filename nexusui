-- UTILS
local function Tween(o, p, t, s, d)
    TS:Create(o, TweenInfo.new(t or 0.22, s or Enum.EasingStyle.Quint, d or Enum.EasingDirection.Out), p):Play()
end
local function New(c, p, ch)
    local i = Instance.new(c)
    for k,v in pairs(p or {}) do i[k]=v end
    for _,x in ipairs(ch or {}) do x.Parent=i end
    return i
end
local function Corner(r, p)
    local c = Instance.new("UICorner"); c.CornerRadius=UDim.new(0,r or 6); c.Parent=p; return c
end
local function Stroke(col, th, tr, p)
    local s = Instance.new("UIStroke")
    s.Color=col or T.Border; s.Thickness=th or 1; s.Transparency=tr or 0
    s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border; s.Parent=p; return s
end
local function Pad(t,r,b,l,p)
    local u=Instance.new("UIPadding")
    u.PaddingTop=UDim.new(0,t or 0); u.PaddingRight=UDim.new(0,r or 0)
    u.PaddingBottom=UDim.new(0,b or 0); u.PaddingLeft=UDim.new(0,l or 0); u.Parent=p
end
local function List(dir, ha, gap, p)
    local l=Instance.new("UIListLayout")
    l.FillDirection=dir or Enum.FillDirection.Vertical
    l.HorizontalAlignment=ha or Enum.HorizontalAlignment.Left
    l.SortOrder=Enum.SortOrder.LayoutOrder; l.Padding=UDim.new(0,gap or 0); l.Parent=p; return l
end
local function AutoCanvas(list, scroll, extra)
    list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize=UDim2.new(0,0,0,list.AbsoluteContentSize.Y+(extra or 8))
    end)
end
local function Shadow(parent, sz, tr)
    return New("ImageLabel",{
        Name="Shadow", AnchorPoint=Vector2.new(0.5,0.5), BackgroundTransparency=1,
        Position=UDim2.new(0.5,0,0.5,0), Size=UDim2.new(1,sz or 40,1,sz or 40),
        ZIndex=(parent.ZIndex or 1)-1, Image="rbxassetid://6015897843",
        ImageColor3=T.Accent, ImageTransparency=tr or 0.72,
        ScaleType=Enum.ScaleType.Slice, SliceCenter=Rect.new(49,49,450,450), Parent=parent,
    })
end
local function Noise(parent, tr)
    New("ImageLabel",{
        BackgroundTransparency=1, Size=UDim2.new(1,0,1,0),
        ZIndex=(parent.ZIndex or 1)+1, Image="rbxassetid://9968344532",
        ImageTransparency=tr or 0.92, ImageColor3=T.AccentGlow,
        ScaleType=Enum.ScaleType.Tile, TileSize=UDim2.new(0,64,0,64), Parent=parent,
    })
end
local function Shimmer(parent, zi)
    local s=New("Frame",{
        BackgroundColor3=T.GlassLight, BackgroundTransparency=0.78, BorderSizePixel=0,
        Position=UDim2.new(0,10,0,0), Size=UDim2.new(1,-20,0,1), ZIndex=zi or 15, Parent=parent,
    }); Corner(1,s); return s
end
local function Draggable(frame, handle)
    local drag,ds,sp=false,nil,nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true; ds=i.Position; sp=frame.Position
            i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then drag=false end end)
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-ds
            frame.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
        end
    end)
end

-- NOTIFICATIONS
local NH
local function MakeNH(gui)
    NH=New("Frame",{Name="Notifications",AnchorPoint=Vector2.new(1,1),BackgroundTransparency=1,
        Position=UDim2.new(1,-16,1,-16),Size=UDim2.new(0,300,1,0),ZIndex=200,Parent=gui})
    local l=List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Right,8,NH)
    l.VerticalAlignment=Enum.VerticalAlignment.Bottom
end
local function Notify(cfg)
    cfg=cfg or {}
    local title=cfg.Title or "Notification"; local desc=cfg.Description or ""
    local dur=cfg.Duration or 4;              local ntype=cfg.Type or "info"
    local bc=T.Accent
    if ntype=="success" then bc=T.Success elseif ntype=="warning" then bc=T.Warning elseif ntype=="danger" then bc=T.Danger end
    local card=New("Frame",{BackgroundColor3=T.Surface,BackgroundTransparency=0.2,BorderSizePixel=0,
        Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,ZIndex=200,Parent=NH})
    Corner(10,card); Stroke(bc,1,0.4,card); Shadow(card,24,0.6); Noise(card,0.93)
    Shimmer(card,202)
    New("Frame",{BackgroundColor3=bc,BorderSizePixel=0,Size=UDim2.new(0,3,1,0),ZIndex=201,Parent=card})
    Corner(4,card:FindFirstChild("Frame"))
    New("UIGradient",{Color=ColorSequence.new(bc,T.AccentDark),Rotation=90,Parent=card:FindFirstChild("Frame")})
    local inner=New("Frame",{BackgroundTransparency=1,Position=UDim2.new(0,12,0,0),Size=UDim2.new(1,-12,1,0),
        AutomaticSize=Enum.AutomaticSize.Y,ZIndex=201,Parent=card})
    Pad(10,10,10,4,inner); List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Left,3,inner)
    New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,14),Font=Enum.Font.GothamBold,
        Text=title,TextColor3=T.Text,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=202,Parent=inner})
    New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
        Font=Enum.Font.Gotham,Text=desc,TextColor3=T.TextMuted,TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=202,Parent=inner})
    local pbg=New("Frame",{BackgroundColor3=T.SurfaceTop,BorderSizePixel=0,
        Position=UDim2.new(0,0,1,-2),Size=UDim2.new(1,0,0,2),ZIndex=203,Parent=card})
    Corner(2,pbg)
    local pf=New("Frame",{BackgroundColor3=bc,BorderSizePixel=0,Size=UDim2.new(1,0,1,0),ZIndex=204,Parent=pbg})
    Corner(2,pf)
    New("UIGradient",{Color=ColorSequence.new(T.AccentGlow,bc),Parent=pf})
    card.Position=UDim2.new(1,320,0,0)
    Tween(card,{Position=UDim2.new(0,0,0,0)},0.35,Enum.EasingStyle.Back)
    Tween(pf,{Size=UDim2.new(0,0,1,0)},dur,Enum.EasingStyle.Linear)
    task.delay(dur,function()
        Tween(card,{Position=UDim2.new(1,320,0,0)},0.3)
        task.wait(0.35)
        if card and card.Parent then card:Destroy() end
    end)
end

