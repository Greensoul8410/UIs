		TabImage.BackgroundTransparency = 1
		TabImage.BorderSizePixel = 0
		TabImage.Position = UDim2.new(0, 9, 0.5, 0)
		TabImage.Size = UDim2.new(0, 16, 0, 16)
		TabImage.Image = cftab.Icon
		TabImage.ImageTransparency = 0.6
		TabImage.ImageColor3 = Color3.fromRGB(230, 230, 230)

		TabButton.Name = "TabButton"
		TabButton.Parent = Tab
		TabButton.BackgroundTransparency = 1
		TabButton.BorderSizePixel = 0
		TabButton.Size = UDim2.new(1, 0, 1, 0)
		TabButton.Text = ""

		-- Tab label: shift right if icon present
		local hasIcon = cftab.Icon ~= nil and cftab.Icon ~= ""
		TabName.Name = "TabName"
		TabName.Parent = Tab
		TabName.AnchorPoint = Vector2.new(0, 0.5)
		TabName.BackgroundTransparency = 1
		TabName.BorderSizePixel = 0
		TabName.Position = UDim2.new(0, hasIcon and 35 or 12, 0.5, 0)
		TabName.Size = UDim2.new(1, hasIcon and -48 or -24, 0, 12)
		TabName.FontFace = Font.new([[rbxasset://fonts/families/GothamSSm.json]], Enum.FontWeight.SemiBold, Enum.FontStyle.Normal)
		TabName.Text = cftab.Title
		TabName.TextColor3 = Color3.fromRGB(230, 230, 230)
		TabName.TextSize = 12
		TabName.TextTransparency = 0.6
		TabName.TextXAlignment = Enum.TextXAlignment.Left

		-- Content scrolling frame
		ScrollLayers.Name = "ScrollLayers"
		ScrollLayers.Parent = LayersFolder
		ScrollLayers.Active = true
		ScrollLayers.BackgroundTransparency = 1
		ScrollLayers.BorderSizePixel = 0
		ScrollLayers.Size = UDim2.new(1, 0, 1, 0)
		ScrollLayers.ScrollBarImageColor3 = Color3.fromRGB(230, 230, 230)
		ScrollLayers.CanvasSize = UDim2.new(0, 0, 0, 0)
		ScrollLayers.AutomaticCanvasSize = Enum.AutomaticSize.Y
		ScrollLayers.ScrollBarImageTransparency = 0.85
		ScrollLayers.ScrollBarThickness = 3
		ScrollLayers.LayoutOrder = Counts

		UIListLayout_Content.Parent = ScrollLayers
		UIListLayout_Content.SortOrder = Enum.SortOrder.LayoutOrder
		UIListLayout_Content.Padding = UDim.new(0, 4)

		-- Active indicator (blue bar)
		if Counts == 0 then
			local ChoosingFrame = Instance.new("Frame")
			local UICorner_CF = Instance.new("UICorner")
			local UIStroke_CF = Instance.new("UIStroke")
			ChoosingFrame.Name = "ChoosingFrame"
			ChoosingFrame.Parent = Tab
			ChoosingFrame.BackgroundColor3 = Color3.fromRGB(93, 197, 248)
			ChoosingFrame.BorderSizePixel = 0
			ChoosingFrame.Position = UDim2.new(0, 1, 0, 10)
			ChoosingFrame.Size = UDim2.new(0, 2, 0, 12)
			UICorner_CF.Parent = ChoosingFrame
			UIStroke_CF.Color = Color3.fromRGB(93, 197, 248)
			UIStroke_CF.Thickness = 0.6
			UIStroke_CF.Parent = ChoosingFrame
		end

		if Counts == 0 then
			LayersPageLayout:JumpToIndex(0)
			BackButton.Text = TabName.Text
			TabImage.ImageTransparency = 0
			Tab.BackgroundTransparency = 0.97
			TabName.TextTransparency = 0
		end

		TabButton.Activated:Connect(function()
			local RealChooseFrame
			for _, v in next, Tab.Parent:GetChildren() do
				for _, frame in next, v:GetChildren() do
					if frame.Name == "ChoosingFrame" then
						RealChooseFrame = frame
						break
					end
				end
			end

			if RealChooseFrame ~= nil and LayersPageLayout.CurrentPage ~= ScrollLayers then
				for _, v in next, Tab.Parent:GetChildren() do
					if v.ClassName ~= "UIListLayout" then
						obj.TweenObject({v, 0.5, "BackgroundTransparency", 0.999})
						if v:FindFirstChild("TabImage") then
							obj.TweenObject({v.TabImage, 0.5, "ImageTransparency", 0.6})
						end
						if v:FindFirstChild("TabName") then
							obj.TweenObject({v.TabName, 0.5, "TextTransparency", 0.6})
						end
					end
				end
				obj.TweenObject({Tab, 0.5, "BackgroundTransparency", 0.97})
				obj.TweenObject({TabImage, 0.5, "ImageTransparency", 0})
				obj.TweenObject({TabName, 0.5, "TextTransparency", 0})
				obj.TweenObject({RealChooseFrame, 0.5, "Position", UDim2.new(0, 1, 0, 9 + (34 * ScrollLayers.LayoutOrder))})
				JumpTo(ScrollLayers.LayoutOrder, TabName.Text)
			end
		end)

		local currentCounts = Counts
		Counts = Counts + 1

		-- ============================================================
		-- Section API
		-- ============================================================
		local Sec = {}

		-- [FEATURE] Redz-style flat Section (labeled divider)
		-- [FIX] Fixed typo: both AddSection and AddSecion work
		-- [FIX] Single shared counter for ALL content (sections, buttons,
		--       toggles) so insertion order is always preserved correctly
		local ContentOrder = 0

		local function MakeSection(ConfigSelection, targetParent)
			ConfigSelection = ConfigSelection or {}
			ConfigSelection.Title = ConfigSelection.Title or "Section"
			ConfigSelection.Icon  = ConfigSelection.Icon  or ""

			-- [FIX] Each section gets the next slot in the shared counter
			ContentOrder = ContentOrder + 1

			-- Outer row: uses a horizontal UIListLayout so icon +
			-- label + line all sit in a single row cleanly
			local SectionRow = Instance.new("Frame")
			SectionRow.Name = ConfigSelection.Title
			SectionRow.Parent = targetParent
			SectionRow.BackgroundTransparency = 1
			SectionRow.BorderSizePixel = 0
			SectionRow.Size = UDim2.new(1, -8, 0, 20)
			SectionRow.LayoutOrder = ContentOrder
			SectionRow.ClipsDescendants = false

			local RowLayout = Instance.new("UIListLayout")
			RowLayout.FillDirection = Enum.FillDirection.Horizontal
			RowLayout.VerticalAlignment = Enum.VerticalAlignment.Center
			RowLayout.SortOrder = Enum.SortOrder.LayoutOrder
			RowLayout.Padding = UDim.new(0, 4)
			RowLayout.Parent = SectionRow

			-- Left padding
			local LeftPad = Instance.new("Frame")
			LeftPad.BackgroundTransparency = 1
			LeftPad.Size = UDim2.new(0, 2, 1, 0)
			LeftPad.BorderSizePixel = 0
			LeftPad.LayoutOrder = 0
			LeftPad.Parent = SectionRow

			-- Icon (optional)
			local hasSecIcon = ConfigSelection.Icon ~= nil and ConfigSelection.Icon ~= ""
			if hasSecIcon then
				local SecIcon = Instance.new("ImageLabel")
				SecIcon.Name = "SectionIcon"
				SecIcon.BackgroundTransparency = 1
				SecIcon.Size = UDim2.new(0, 12, 0, 12)
				SecIcon.Image = ConfigSelection.Icon
				SecIcon.ImageColor3 = Color3.fromRGB(130, 130, 130)
				SecIcon.LayoutOrder = 1
				SecIcon.Parent = SectionRow
			end

			-- Label (AutomaticSize so TextBounds never matters)
			local SectionLabel = Instance.new("TextLabel")
			SectionLabel.Name = "SectionLabel"
			SectionLabel.BackgroundTransparency = 1
			SectionLabel.AutomaticSize = Enum.AutomaticSize.X
			SectionLabel.Size = UDim2.new(0, 0, 1, 0) -- width driven by AutomaticSize
			SectionLabel.Font = Enum.Font.GothamBold
			SectionLabel.Text = ConfigSelection.Title
			SectionLabel.TextColor3 = Color3.fromRGB(130, 130, 130)
			SectionLabel.TextSize = 10
			SectionLabel.TextXAlignment = Enum.TextXAlignment.Left
			SectionLabel.LayoutOrder = 2
			SectionLabel.Parent = SectionRow

			-- Line: fills the remaining horizontal space
			local SectionLine = Instance.new("Frame")
			SectionLine.Name = "SectionLine"
			SectionLine.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
			SectionLine.BorderSizePixel = 0
			SectionLine.AnchorPoint = Vector2.new(0, 0.5)
			SectionLine.Size = UDim2.new(1, 0, 0, 1) -- fills remaining via layout
			SectionLine.LayoutOrder = 3
			SectionLine.Parent = SectionRow

			-- Make the line fill whatever space is left after icon+label
			-- by using a UISizeConstraint approach: let the row be a
			-- normal frame but make the line use fill via a separate frame
			-- [FIX] Simpler: don't put line in UIListLayout — position it
			-- absolutely anchored to the right of the label instead
			RowLayout:Destroy() -- remove the list layout approach

			-- Rebuild with absolute positioning (reliable across all executors)
			-- Icon at left
			if hasSecIcon then
				local icon = SectionRow:FindFirstChild("SectionIcon")
				if icon then
					icon.AnchorPoint = Vector2.new(0, 0.5)
					icon.Position = UDim2.new(0, 2, 0.5, 0)
					icon.Size = UDim2.new(0, 12, 0, 12)
				end
			end
			LeftPad:Destroy()

			local iconOffset = hasSecIcon and 20 or 0
			SectionLabel.AutomaticSize = Enum.AutomaticSize.X
			SectionLabel.AnchorPoint = Vector2.new(0, 0.5)
			SectionLabel.Position = UDim2.new(0, iconOffset + 2, 0.5, 0)
			SectionLabel.Size = UDim2.new(0, 0, 1, 0)

			SectionLine:Destroy() -- recreate outside layout
			local Line = Instance.new("Frame")
			Line.Name = "SectionLine"
			Line.Parent = SectionRow
			Line.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
			Line.BorderSizePixel = 0
			Line.AnchorPoint = Vector2.new(0, 0.5)
			-- [FIX] Position line using AbsoluteSize signal so it always
			-- starts right after the label text regardless of load timing
			local function UpdateLine()
				local tbX = SectionLabel.TextBounds.X
				local startX = iconOffset + 2 + tbX + 5
				Line.Position = UDim2.new(0, startX, 0.5, 0)
				Line.Size = UDim2.new(1, -startX - 4, 0, 1)
			end
			-- Update immediately and again once text renders
			UpdateLine()
			SectionLabel:GetPropertyChangedSignal("TextBounds"):Connect(UpdateLine)

			-- InSec API (items go directly into ScrollLayers)
			local InSec = {}

			function InSec:AddButton(Mode, ConfigButton)
				local FeatureParent = ScrollLayers
				ConfigButton = ConfigButton or {}
				ConfigButton.Title = ConfigButton.Title or "Button"
				ConfigButton.Icon = ConfigButton.Icon or cftab.Icon
				ConfigButton.ClickName = ConfigButton.ClickName or "Click"
				ConfigButton.Description = ConfigButton.Description or ""
				ConfigButton.Callback = ConfigButton.Callback or function() end

				local Button = Instance.new("Frame")
				local UICorner_Btn = Instance.new("UICorner")
				local ButtonContent = Instance.new("TextLabel")
				local ButtonImage = Instance.new("ImageLabel")
				local ButtonTitle = Instance.new("TextLabel")
				local ButtonFrame = Instance.new("Frame")
				local UICorner_BtnF = Instance.new("UICorner")
				local ButtonButton = Instance.new("TextButton")

				Button.Name = ConfigButton.Title
				Button.Parent = FeatureParent
				Button.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				Button.BackgroundTransparency = 0.97
				Button.BorderSizePixel = 0
				Button.LayoutOrder = (function() ContentOrder = ContentOrder + 1; return ContentOrder end)()
				Button.Size = UDim2.new(1, -8, 0, 45)
				UICorner_Btn.CornerRadius = UDim.new(0, 4)
				UICorner_Btn.Parent = Button

				ButtonContent.Name = "ButtonContent"
				ButtonContent.Parent = Button
				ButtonContent.BackgroundTransparency = 1
				ButtonContent.Position = UDim2.new(0, 40, 0, 21)
				ButtonContent.Size = UDim2.new(1, -190, 0, 11)
				ButtonContent.Font = Enum.Font.GothamMedium
				ButtonContent.Text = ConfigButton.Description
				ButtonContent.TextColor3 = Color3.fromRGB(255, 255, 255)
				ButtonContent.TextSize = 11
				ButtonContent.TextTransparency = 0.6
				ButtonContent.TextXAlignment = Enum.TextXAlignment.Left

				ButtonImage.Name = "ButtonImage"
				ButtonImage.Parent = Button
				ButtonImage.AnchorPoint = Vector2.new(0, 0.5)
				ButtonImage.BackgroundTransparency = 1
				ButtonImage.Position = UDim2.new(0, 12, 0.5, 0)
				ButtonImage.Size = UDim2.new(0, 16, 0, 16)
				ButtonImage.Image = ConfigButton.Icon

				ButtonTitle.Name = "ButtonTitle"
				ButtonTitle.Parent = Button
				ButtonTitle.BackgroundTransparency = 1
				ButtonTitle.Position = UDim2.new(0, 40, 0, 11)
				ButtonTitle.Size = UDim2.new(1, -190, 0, 12)
				ButtonTitle.FontFace = Font.new([[rbxasset://fonts/families/GothamSSm.json]], Enum.FontWeight.SemiBold, Enum.FontStyle.Normal)
				ButtonTitle.Text = ConfigButton.Title
				ButtonTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
				ButtonTitle.TextSize = 12
				ButtonTitle.TextXAlignment = Enum.TextXAlignment.Left

				ButtonFrame.Name = "ButtonFrame"
				ButtonFrame.Parent = Button
				ButtonFrame.AnchorPoint = Vector2.new(1, 0.5)
				ButtonFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				ButtonFrame.BackgroundTransparency = 0.96
				ButtonFrame.BorderSizePixel = 0
				ButtonFrame.Position = UDim2.new(1, -9, 0.5, 0)
				ButtonFrame.Size = UDim2.new(0, 125, 0, 26)
				UICorner_BtnF.CornerRadius = UDim.new(0, 4)
				UICorner_BtnF.Parent = ButtonFrame
				obj.Mouseto(ButtonFrame, function()
					ButtonFrame.BackgroundTransparency = 0.94
				end, function()
					ButtonFrame.BackgroundTransparency = 0.96
				end)

				ButtonButton.Name = "ButtonButton"
				ButtonButton.Parent = ButtonFrame
				ButtonButton.BackgroundTransparency = 1
				ButtonButton.BorderSizePixel = 0
				ButtonButton.Size = UDim2.new(1, 0, 1, 0)
				ButtonButton.Font = Enum.Font.GothamMedium
				ButtonButton.TextColor3 = Color3.fromRGB(178, 178, 178)
				ButtonButton.TextSize = 11
				ButtonButton.Text = ConfigButton.ClickName

				if ConfigButton.Description == "" then
					ButtonTitle.Position = UDim2.new(0, 40, 0, 0)
					ButtonTitle.Size = UDim2.new(1, -190, 1, 0)
				end

				obj.Click(ButtonButton, function()
					ButtonFrame.BackgroundTransparency = 0.85
					obj.TweenObject({ButtonFrame, 0.9, "BackgroundTransparency", 0.96})
					ConfigButton.Callback()
				end)
			end

			function InSec:AddToggle(Mode, ConfigToggles)
				local FeatureParent = ScrollLayers
				ConfigToggles = ConfigToggles or {}
				ConfigToggles.Title = ConfigToggles.Title or "Toggle"
				ConfigToggles.Description = ConfigToggles.Description or ""
				ConfigToggles.IconToggle = ConfigToggles.IconToggle or cftab.Icon
				ConfigToggles.Default = ConfigToggles.Default or false
				ConfigToggles.Callback = ConfigToggles.Callback or function() end

				local Toggle = Instance.new("Frame")
				local UICorner_Tog = Instance.new("UICorner")
				local ToggleTitle = Instance.new("TextLabel")
				local ToggleContent = Instance.new("TextLabel")
				local ToggleImage = Instance.new("ImageLabel")
				local ToggleSwitch = Instance.new("Frame")
				local UICorner_TS = Instance.new("UICorner")
				local ToggleCircle = Instance.new("Frame")
				local UICorner_TC = Instance.new("UICorner")
				local UIStroke_TC = Instance.new("UIStroke")
				local ToggleButton = Instance.new("TextButton")
				local ToggleFunc = {Enabled = ConfigToggles.Default}

				Toggle.Name = ConfigToggles.Title
				Toggle.Parent = FeatureParent
				Toggle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				Toggle.BackgroundTransparency = 0.97
				Toggle.BorderSizePixel = 0
				Toggle.LayoutOrder = (function() ContentOrder = ContentOrder + 1; return ContentOrder end)()
				Toggle.Size = UDim2.new(1, -8, 0, 45)
				obj.Mouseto(Toggle, function()
					Toggle.BackgroundTransparency = 0.95
				end, function()
					Toggle.BackgroundTransparency = 0.97
				end)
				UICorner_Tog.CornerRadius = UDim.new(0, 4)
				UICorner_Tog.Parent = Toggle

				ToggleTitle.Name = "ToggleTitle"
				ToggleTitle.Parent = Toggle
				ToggleTitle.BackgroundTransparency = 1
				ToggleTitle.Position = UDim2.new(0, 40, 0, 11)
				ToggleTitle.Size = UDim2.new(1, -158, 0, 12)
				ToggleTitle.FontFace = Font.new([[rbxasset://fonts/families/GothamSSm.json]], Enum.FontWeight.SemiBold, Enum.FontStyle.Normal)
				ToggleTitle.Text = ConfigToggles.Title
				ToggleTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
				ToggleTitle.TextSize = 12
				ToggleTitle.TextXAlignment = Enum.TextXAlignment.Left

				ToggleContent.Name = "ToggleContent"
				ToggleContent.Parent = Toggle
				ToggleContent.BackgroundTransparency = 1
				ToggleContent.Position = UDim2.new(0, 40, 0, 21)
				ToggleContent.Size = UDim2.new(1, -158, 0, 11)
				ToggleContent.Font = Enum.Font.GothamMedium
				ToggleContent.Text = ConfigToggles.Description
				ToggleContent.TextColor3 = Color3.fromRGB(255, 255, 255)
				ToggleContent.TextSize = 11
				ToggleContent.TextTransparency = 0.6
				ToggleContent.TextXAlignment = Enum.TextXAlignment.Left

				ToggleImage.Name = "ToggleImage"
				ToggleImage.Parent = Toggle
				ToggleImage.AnchorPoint = Vector2.new(0, 0.5)
				ToggleImage.BackgroundTransparency = 1
				ToggleImage.Position = UDim2.new(0, 12, 0.5, 0)
				ToggleImage.Size = UDim2.new(0, 16, 0, 16)
				ToggleImage.Image = ConfigToggles.IconToggle

				ToggleSwitch.Name = "ToggleSwitch"
				ToggleSwitch.Parent = Toggle
				ToggleSwitch.AnchorPoint = Vector2.new(1, 0.5)
				ToggleSwitch.BackgroundColor3 = Color3.fromRGB(93, 197, 248)
				ToggleSwitch.BackgroundTransparency = 0.999
				ToggleSwitch.BorderSizePixel = 0
				ToggleSwitch.Position = UDim2.new(1, -25, 0.5, 0)
				ToggleSwitch.Size = UDim2.new(0, 32, 0, 16)
				UICorner_TS.Parent = ToggleSwitch

				ToggleCircle.Name = "ToggleCircle"
				ToggleCircle.Parent = ToggleSwitch
				ToggleCircle.AnchorPoint = Vector2.new(0, 0.5)
				ToggleCircle.BackgroundColor3 = Color3.fromRGB(113, 111, 112)
				ToggleCircle.BorderSizePixel = 0
				ToggleCircle.Position = UDim2.new(0, 2, 0.5, 0)
				ToggleCircle.Size = UDim2.new(0, 12, 0, 12)
				UICorner_TC.Parent = ToggleCircle
				UIStroke_TC.Parent = ToggleCircle

				ToggleButton.Name = "ToggleButton"
				ToggleButton.Parent = Toggle
				ToggleButton.BackgroundTransparency = 1
				ToggleButton.BorderSizePixel = 0
				ToggleButton.Size = UDim2.new(1, 0, 1, 0)
				ToggleButton.Text = ""

				local function SetToggle(state)
					ToggleFunc.Enabled = state
					if state then
						obj.TweenObject({ToggleSwitch, 0.3, "BackgroundTransparency", 0})
						obj.TweenObject({ToggleCircle, 0.3, "Position", UDim2.new(1, -14, 0.5, 0)})
						obj.TweenObject({ToggleCircle, 0.3, "BackgroundColor3", Color3.fromRGB(255, 255, 255)})
					else
						obj.TweenObject({ToggleSwitch, 0.3, "BackgroundTransparency", 0.999})
						obj.TweenObject({ToggleCircle, 0.3, "Position", UDim2.new(0, 2, 0.5, 0)})
						obj.TweenObject({ToggleCircle, 0.3, "BackgroundColor3", Color3.fromRGB(113, 111, 112)})
					end
					ConfigToggles.Callback(state)
				end

				SetToggle(ConfigToggles.Default)

				ToggleButton.Activated:Connect(function()
					SetToggle(not ToggleFunc.Enabled)
				end)

				if ConfigToggles.Description == "" then
					ToggleTitle.Position = UDim2.new(0, 40, 0, 0)
					ToggleTitle.Size = UDim2.new(1, -158, 1, 0)
				end

				return ToggleFunc
			end

			return InSec
		end

		-- Public API: AddSection (fixed spelling) + legacy alias AddSecion
		function Sec:AddSection(ConfigSelection)
			return MakeSection(ConfigSelection, ScrollLayers)
		end

		-- [FIX] Keep typo alias so existing scripts don't break
		Sec.AddSecion = Sec.AddSection

		return Sec
	end

	-- ============================================================
	-- Notification API exposed on UITab
	-- ============================================================
	function UITab:Notify(cfg)
		return FireNotification(Window, cfg)
	end

	return UITab
end

return obj

