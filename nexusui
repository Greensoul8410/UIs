            local S={}

            -- TOGGLE
            function S:AddToggle(c)
                c=c or {}
                local r=Row(46); Labels(r,c.Title or "Toggle",c.Description or "")
                local def=c.Default or false; local cb=c.Callback or function() end
                local track=New("Frame",{AnchorPoint=Vector2.new(1,0.5),BackgroundColor3=T.SurfaceTop,
                    BorderSizePixel=0,Position=UDim2.new(1,-12,0.5,0),Size=UDim2.new(0,40,0,21),ZIndex=15,Parent=r})
                Corner(11,track); Stroke(T.Border,1,0.2,track)
                local circle=New("Frame",{AnchorPoint=Vector2.new(0,0.5),BackgroundColor3=T.TextDim,
                    BorderSizePixel=0,Position=UDim2.new(0,3,0.5,0),Size=UDim2.new(0,15,0,15),ZIndex=16,Parent=track})
                Corner(100,circle)
                local tglow=New("ImageLabel",{AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,
                    Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(1,20,1,20),ZIndex=14,
                    Image="rbxassetid://6015897843",ImageColor3=T.Accent,ImageTransparency=1,
                    ScaleType=Enum.ScaleType.Slice,SliceCenter=Rect.new(49,49,450,450),Parent=track})
                local on=def
                local function Set(state,silent)
                    on=state
                    if state then
                        local g=track:FindFirstChildWhichIsA("UIGradient")
                        if not g then New("UIGradient",{Color=ColorSequence.new(T.AccentGlow,T.AccentDark),Parent=track}) end
                        Tween(track,{BackgroundColor3=T.AccentDark},0.22)
                        Tween(circle,{Position=UDim2.new(0,22,0.5,0),BackgroundColor3=T.AccentBright},0.22)
                        Tween(tglow,{ImageTransparency=0.78},0.22)
                    else
                        local g=track:FindFirstChildWhichIsA("UIGradient"); if g then g:Destroy() end
                        Tween(track,{BackgroundColor3=T.SurfaceTop},0.22)
                        Tween(circle,{Position=UDim2.new(0,3,0.5,0),BackgroundColor3=T.TextDim},0.22)
                        Tween(tglow,{ImageTransparency=1},0.22)
                    end
                    if not silent then cb(state) end
                end
                Set(def,true)
                New("TextButton",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text="",ZIndex=17,Parent=r})
                    .MouseButton1Click:Connect(function() Set(not on) end)
                return {Set=Set,Get=function() return on end}
            end

            -- BUTTON
            function S:AddButton(c)
                c=c or {}
                local r=Row(46); Labels(r,c.Title or "Button",c.Description or "")
                local clk=c.ClickName or "Click"; local cb=c.Callback or function() end
                local pill=New("TextButton",{AnchorPoint=Vector2.new(1,0.5),BackgroundColor3=T.SurfaceTop,
                    BackgroundTransparency=0.2,BorderSizePixel=0,Position=UDim2.new(1,-12,0.5,0),
                    Size=UDim2.new(0,84,0,26),Font=Enum.Font.GothamSemibold,Text=clk,
