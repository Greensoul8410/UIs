            -- SLIDER
            function S:AddSlider(c)
                c=c or {}; local mn=c.Min or 0; local mx=c.Max or 100
                local def=c.Default or mn; local inc=c.Increment or 1
                local cb=c.Callback or function() end
                local r=Row(54); Labels(r,c.Title or "Slider",c.Description or "")
                local vl=I("TextLabel",{AnchorPoint=Vector2.new(1,0),BackgroundTransparency=1,
                    Position=UDim2.new(1,-12,0,8),Size=UDim2.new(0,52,0,14),
                    Font=Enum.Font.GothamBold,Text=tostring(def),
                    TextColor3=C.AccentHi,TextSize=12,
                    TextXAlignment=Enum.TextXAlignment.Right,ZIndex=5,Parent=r})
                local tbg=I("Frame",{BackgroundColor3=C.Track,BorderSizePixel=0,
                    Position=UDim2.new(0,12,1,-14),Size=UDim2.new(1,-24,0,5),
                    ZIndex=5,Parent=r})
                Corner(4,tbg)
                local fill=I("Frame",{BackgroundColor3=C.Accent,BorderSizePixel=0,
                    Size=UDim2.new(0,0,1,0),ZIndex=6,Parent=tbg})
                Corner(4,fill)
                I("UIGradient",{Color=ColorSequence.new(C.AccentHi,C.Accent),Parent=fill})
                local handle=I("Frame",{AnchorPoint=Vector2.new(0.5,0.5),
                    BackgroundColor3=Color3.fromRGB(230,230,230),BorderSizePixel=0,
                    Position=UDim2.new(0,0,0.5,0),Size=UDim2.new(0,13,0,13),ZIndex=7,Parent=tbg})
                Corner(100,handle)
                Stroke(C.Accent,2,0,handle)
                local cur=def
                local function SV(v,silent)
                    v=math.clamp(math.round(v/inc)*inc,mn,mx); cur=v
                    local p=(v-mn)/(mx-mn)
                    TW(fill,{Size=UDim2.new(p,0,1,0)},0.08)
                    TW(handle,{Position=UDim2.new(p,0,0.5,0)},0.08)
                    vl.Text=tostring(v); if not silent then cb(v) end
                end
                SV(def,true)
                local sliding=false
                I("TextButton",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),
                    Text="",ZIndex=8,Parent=tbg}).MouseButton1Down:Connect(function() sliding=true end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end
                end)
                local conn; conn=RS.RenderStepped:Connect(function()
                    if not sliding then return end
                    local ap=tbg.AbsolutePosition; local as=tbg.AbsoluteSize
                    local ml=UIS:GetMouseLocation()
                    SV(mn+(mx-mn)*math.clamp((ml.X-ap.X)/as.X,0,1))
                end)
                tbg.AncestryChanged:Connect(function()
                    if not tbg:IsDescendantOf(game) then conn:Disconnect() end
                end)
                return {Set=SV,Get=function() return cur end}
            end

            -- DROPDOWN  (rebuilt: animated open/close, arrow spins, proper hit detection)
            function S:AddDropdown(c)
                c=c or {}; local vals=c.Values or {}; local def=c.Default or {}
                local multi=c.Multi or false; local cb=c.Callback or function() end
                if type(def)=="string" then def={def} end
                local sel={}; for _,v in ipairs(def) do sel[v]=true end

                local r=Row(46); Labels(r,c.Title or "Dropdown",c.Description or "")

                local function ST()
                    local k={}; for v in pairs(sel) do table.insert(k,v) end
                    if #k==0 then return "None"
                    elseif #k==1 then return k[1]
                    else return k[1].." +"..tostring(#k-1) end
                end

                -- dropdown trigger button (wider, right-aligned)
                local drow=I("Frame",{AnchorPoint=Vector2.new(1,0.5),
                    BackgroundColor3=Color3.fromRGB(45,45,45),BackgroundTransparency=0.2,
                    BorderSizePixel=0,Position=UDim2.new(1,-12,0.5,0),
                    Size=UDim2.new(0,132,0,28),ZIndex=5,Parent=r})
                Corner(6,drow)
                Stroke(Color3.fromRGB(80,80,80),1,0.3,drow)

                local dtxt=I("TextLabel",{BackgroundTransparency=1,
                    Position=UDim2.new(0,8,0,0),Size=UDim2.new(1,-26,1,0),
                    Font=Enum.Font.Gotham,Text=ST(),TextColor3=C.TextDim,TextSize=11,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    TextTruncate=Enum.TextTruncate.AtEnd,ZIndex=6,Parent=drow})
                local arrow=I("TextLabel",{AnchorPoint=Vector2.new(1,0.5),
                    BackgroundTransparency=1,Position=UDim2.new(1,-5,0.5,0),
                    Size=UDim2.new(0,16,0,16),Font=Enum.Font.GothamBold,
                    Text="v",TextColor3=C.TextDim,TextSize=10,ZIndex=6,Parent=drow})
                local dbtn=I("TextButton",{BackgroundTransparency=1,
                    Size=UDim2.new(1,0,1,0),Text="",ZIndex=7,Parent=drow})

                drow.MouseEnter:Connect(function()
                    TW(drow,{BackgroundTransparency=0},0.12)
                    local st=drow:FindFirstChildWhichIsA("UIStroke")
                    if st then TW(st,{Color=C.Accent,Transparency=0.4},0.12) end
                end)
                drow.MouseLeave:Connect(function()
                    TW(drow,{BackgroundTransparency=0.2},0.12)
                    local st=drow:FindFirstChildWhichIsA("UIStroke")
                    if st then TW(st,{Color=Color3.fromRGB(80,80,80),Transparency=0.3},0.12) end
                end)

                local open=false; local panel=nil; local ilist={}

                local function CP()
                    if not panel then return end; open=false
                    TW(panel,{Size=UDim2.new(0,132,0,0),BackgroundTransparency=1},0.2)
                    TW(arrow,{Rotation=0},0.2)
                    task.delay(0.22,function()
                        if panel then panel:Destroy(); panel=nil; ilist={} end
                    end)
                end

                local function OP()
                    if panel then CP(); return end; open=true
                    local ph=math.min(#vals*26+8,152)
                    panel=I("Frame",{AnchorPoint=Vector2.new(1,0),
                        BackgroundColor3=C.Win,BackgroundTransparency=C.WinTr,
                        BorderSizePixel=0,
                        Position=UDim2.new(1,0,1,4),
                        Size=UDim2.new(0,132,0,0),  -- starts at height 0
                        ClipsDescendants=true,ZIndex=50,Parent=drow})
                    Corner(8,panel)
                    Stroke(C.Accent,1,0.5,panel)
                    DropShadow(panel)

                    local ps=I("ScrollingFrame",{BackgroundTransparency=1,
                        Size=UDim2.new(1,0,1,0),
                        CanvasSize=UDim2.new(0,0,0,#vals*26+8),
                        ScrollBarThickness=2,ScrollBarImageColor3=C.Accent,
                        ZIndex=51,Parent=panel})
                    Pad(4,4,4,4,ps)
                    List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Left,2,ps)

                    for _,val in ipairs(vals) do
                        local isSel=sel[val]==true
                        local item=I("Frame",{
                            BackgroundColor3=isSel and C.Accent or Color3.fromRGB(50,50,50),
                            BackgroundTransparency=isSel and 0.55 or 0,
                            BorderSizePixel=0,Size=UDim2.new(1,0,0,24),ZIndex=52,Parent=ps})
                        Corner(5,item)
                        local itxt=I("TextButton",{BackgroundTransparency=1,
                            Size=UDim2.new(1,0,1,0),Font=Enum.Font.Gotham,Text=val,
                            TextColor3=isSel and C.AccentHi or C.TextDim,TextSize=11,
                            AutoButtonColor=false,ZIndex=53,Parent=item})
                        table.insert(ilist,{val=val,bg=item,txt=itxt})

                        itxt.MouseEnter:Connect(function()
                            if not sel[val] then
                                TW(item,{BackgroundTransparency=0.82},0.1)
                                TW(itxt,{TextColor3=C.Text},0.1)
                            end
                        end)
                        itxt.MouseLeave:Connect(function()
                            if not sel[val] then
                                TW(item,{BackgroundTransparency=0},0.1)
                                TW(itxt,{TextColor3=C.TextDim},0.1)
                            end
                        end)
                        itxt.MouseButton1Click:Connect(function()
                            if multi then
                                if sel[val] then sel[val]=nil else sel[val]=true end
                            else
                                sel={}; sel[val]=true; CP()
                            end
                            dtxt.Text=ST()
                            -- refresh visuals for all items
                            for _,e in ipairs(ilist) do
                                local s=sel[e.val]==true
                                TW(e.bg,{BackgroundColor3=s and C.Accent or Color3.fromRGB(50,50,50),
                                    BackgroundTransparency=s and 0.55 or 0},0.1)
                                TW(e.txt,{TextColor3=s and C.AccentHi or C.TextDim},0.1)
                            end
                            local k={}; for v in pairs(sel) do table.insert(k,v) end
                            cb(multi and k or k[1])
                        end)
                    end

                    -- animate open (height expand + arrow spin)
                    TW(panel,{Size=UDim2.new(0,132,0,ph),BackgroundTransparency=C.WinTr},0.22)
                    TW(arrow,{Rotation=180},0.22)
                end

                dbtn.MouseButton1Click:Connect(OP)

                -- outside click closes
                UIS.InputBegan:Connect(function(inp)
                    if inp.UserInputType~=Enum.UserInputType.MouseButton1 then return end
                    if not open or not panel then return end
                    local ml=UIS:GetMouseLocation()
                    local function inside(f)
                        local ap=f.AbsolutePosition; local as=f.AbsoluteSize
                        return ml.X>=ap.X and ml.X<=ap.X+as.X and ml.Y>=ap.Y and ml.Y<=ap.Y+as.Y
                    end
                    if not inside(panel) and not inside(drow) then CP() end
                end)

                return {
                    Set=function(_,v)
                        sel={}
                        if type(v)=="table" then for _,x in ipairs(v) do sel[x]=true end
                        else sel[v]=true end
                        dtxt.Text=ST()
                    end,
                    Get=function()
                        local k={}; for v in pairs(sel) do table.insert(k,v) end
                        return multi and k or k[1]
                    end,
                }
            end

            -- PARAGRAPH
            function S:AddParagraph(c)
                c=c or {}
                local r=I("Frame",{BackgroundColor3=Color3.fromRGB(255,255,255),
                    BackgroundTransparency=C.RowTr+0.01,BorderSizePixel=0,
