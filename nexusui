-- ════════════════════════════════════════════════════════
--  HELPERS
-- ════════════════════════════════════════════════════════
local function TW(obj, props, t, sty, dir)
    TS:Create(obj, TweenInfo.new(t or 0.25, sty or Enum.EasingStyle.Quint,
        dir or Enum.EasingDirection.Out), props):Play()
end
local function TWBack(obj, props, t)
    TW(obj, props, t or 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end
local function I(cls, props)
    local o = Instance.new(cls)
    for k,v in pairs(props or {}) do o[k]=v end
    return o
end
local function Corner(r,p)
    local c=I("UICorner",{CornerRadius=UDim.new(0,r or 6)}); c.Parent=p; return c
end
local function Stroke(col,th,tr,p)
    local s=I("UIStroke",{Color=col,Thickness=th or 1,Transparency=tr or 0,
        ApplyStrokeMode=Enum.ApplyStrokeMode.Border})
    s.Parent=p; return s
end
local function Pad(t,r,b,l,p)
    I("UIPadding",{PaddingTop=UDim.new(0,t),PaddingRight=UDim.new(0,r),
        PaddingBottom=UDim.new(0,b),PaddingLeft=UDim.new(0,l)}).Parent=p
end
local function List(dir,ha,gap,p)
    local l=I("UIListLayout",{FillDirection=dir or Enum.FillDirection.Vertical,
        HorizontalAlignment=ha or Enum.HorizontalAlignment.Left,
        SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,gap or 0)})
    l.Parent=p; return l
end
local function AutoCanvas(list,sf,extra)
    list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        sf.CanvasSize=UDim2.new(0,0,0,list.AbsoluteContentSize.Y+(extra or 8))
    end)
end
-- rielUI drop shadow (exact copy)
local function DropShadow(parent)
    local h=I("Frame",{BackgroundTransparency=1,BorderSizePixel=0,
        Size=UDim2.new(1,0,1,0),ZIndex=0,Parent=parent})
    I("ImageLabel",{AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,
        BorderSizePixel=0,Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(1,47,1,47),
        ZIndex=0,Image="rbxassetid://6015897843",ImageColor3=Color3.fromRGB(0,0,0),
        ImageTransparency=0.5,ScaleType=Enum.ScaleType.Slice,
        SliceCenter=Rect.new(49,49,450,450),Parent=h})
end
local function Drag(frame,handle)
    local dragging,ds,sp=false,nil,nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=true; ds=i.Position; sp=frame.Position
            i.Changed:Connect(function()
                if i.UserInputState==Enum.UserInputState.End then dragging=false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
            if dragging then
                local d=i.Position-ds
                frame.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
            end
        end
    end)
end

-- ════════════════════════════════════════════════════════
--  NOTIFICATIONS
-- ════════════════════════════════════════════════════════
local NH
local function MakeNH(gui)
    NH=I("Frame",{Name="NH",AnchorPoint=Vector2.new(1,1),BackgroundTransparency=1,
        Position=UDim2.new(1,-12,1,-12),Size=UDim2.new(0,270,1,0),ZIndex=300,Parent=gui})
    local l=List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Right,6,NH)
    l.VerticalAlignment=Enum.VerticalAlignment.Bottom
end
local function Notify(cfg)
    cfg=cfg or {}
    local ntype=cfg.Type or "info"
    local ac=C.Blue
    if ntype=="success" then ac=C.Green
    elseif ntype=="warning" then ac=C.Yellow
    elseif ntype=="danger" then ac=C.Red end
    local dur=cfg.Duration or 4

    local card=I("Frame",{BackgroundColor3=C.Win,BackgroundTransparency=C.WinTr,
        BorderSizePixel=0,Size=UDim2.new(1,0,0,62),ClipsDescendants=false,ZIndex=300,Parent=NH})
    Corner(8,card)
    Stroke(ac,1,0.5,card)
    DropShadow(card)

    -- left bar
    local bar=I("Frame",{BackgroundColor3=ac,BorderSizePixel=0,
        Size=UDim2.new(0,3,1,0),ZIndex=301,Parent=card})
    Corner(6,bar)

    -- dot
    local dot=I("Frame",{BackgroundColor3=ac,BorderSizePixel=0,
        Position=UDim2.new(0,10,0.5,-5),Size=UDim2.new(0,10,0,10),ZIndex=302,Parent=card})
    Corner(100,dot)

    I("TextLabel",{BackgroundTransparency=1,
        Position=UDim2.new(0,28,0,10),Size=UDim2.new(1,-40,0,15),
        Font=Enum.Font.GothamBold,Text=cfg.Title or "Notification",
        TextColor3=C.Text,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=302,Parent=card})
    I("TextLabel",{BackgroundTransparency=1,
        Position=UDim2.new(0,28,0,27),Size=UDim2.new(1,-40,0,22),
        Font=Enum.Font.Gotham,Text=cfg.Description or "",TextColor3=C.TextDim,TextSize=11,
        TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=302,Parent=card})

    -- progress bar
    local pbg=I("Frame",{BackgroundColor3=C.Track,BorderSizePixel=0,
        Position=UDim2.new(0,0,1,-3),Size=UDim2.new(1,0,0,3),ZIndex=301,Parent=card})
    Corner(4,pbg)
    local pf=I("Frame",{BackgroundColor3=ac,BorderSizePixel=0,
        Size=UDim2.new(1,0,1,0),ZIndex=302,Parent=pbg})
    Corner(4,pf)

    -- slide in from right
    card.Position=UDim2.new(1,300,0,0)
    TWBack(card,{Position=UDim2.new(0,0,0,0)},0.45)
    TW(pf,{Size=UDim2.new(0,0,1,0)},dur,Enum.EasingStyle.Linear)
    task.delay(dur,function()
        TW(card,{Position=UDim2.new(1,300,0,0),BackgroundTransparency=1},0.3)
        task.wait(0.35); if card.Parent then card:Destroy() end
    end)
end

