        end -- AddSection
        return TabObj
    end -- AddTab

    -- Welcome notification
    task.delay(0.6,function()
        Notify({Title="NexusUI loaded",Description="Welcome, "..LP.DisplayName.."!",Duration=3,Type="success"})
    end)

    return W
