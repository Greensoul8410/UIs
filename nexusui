local Nexus={}; Nexus.__index=Nexus

function Nexus:Window(cfg)
    cfg=cfg or {}
    local title    = cfg.Title       or "NexusUI"
    local desc     = cfg.Description or ""
    local kc       = cfg.KeyCode     or Enum.KeyCode.RightControl
    local winSize  = cfg.Size        or UDim2.new(0,700,0,480)
    local logoText = cfg.LogoText    or title:sub(1,1):upper()

    -- ── GUI ROOT ─────────────────────────────────────────
    local Gui=I("ScreenGui",{Name="NexusUI",ZIndexBehavior=Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn=false,Parent=PGui})
    MakeNH(Gui)

    -- ── MAIN WINDOW  (rielUI: RGB(30,30,30) @ 0.15) ──────
    local Main=I("Frame",{Name="Window11",
        BackgroundColor3=C.Win, BackgroundTransparency=C.WinTr,
        BorderSizePixel=0,
        Position=UDim2.new(0, VP.X/2 - winSize.X.Offset/2,
                           0, VP.Y/2 - winSize.Y.Offset/2),
        Size=winSize, ZIndex=2, Parent=Gui})
    Corner(10,Main)
    -- rielUI UIStroke_26: white, 2.6 thickness, no explicit transparency
    Stroke(C.StrokeWin, 2.6, C.StrokeWinTr, Main)
    DropShadow(Main)

    -- ── TITLE BAR  (rielUI: white 0.999 = effectively transparent) ───
    local TB=I("Frame",{BackgroundColor3=Color3.fromRGB(255,255,255),
        BackgroundTransparency=0.999,BorderSizePixel=0,
        Size=UDim2.new(1,0,0,43),ZIndex=2,Parent=Main})

    I("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,15,0,15),
        Size=UDim2.new(0,300,0,13),Font=Enum.Font.GothamBold,Text=title,
        TextColor3=C.Text,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,
        ZIndex=3,Parent=TB})
    I("TextLabel",{BackgroundTransparency=1,
        Position=UDim2.new(0,15+#title*7+8,0,15),
        Size=UDim2.new(0,200,0,13),Font=Enum.Font.Gotham,Text=desc,
        TextColor3=C.Text,TextTransparency=0.6,TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=TB})

    -- rielUI DecideFrame: thin separator line under titlebar
    local decFrame=I("Frame",{Name="DecideFrame",AnchorPoint=Vector2.new(0.5,1),
        BackgroundColor3=C.DecideLine,BackgroundTransparency=C.DecideTr,
        BorderSizePixel=0,Position=UDim2.new(0.5,0,1,2),
        Size=UDim2.new(1,-14,0,2),ZIndex=3,Parent=TB})
    Corner(100,decFrame)
    -- purple accent inner line (our addition on top of rielUI's white one)
    local purpleLine=I("Frame",{AnchorPoint=Vector2.new(0.5,0.5),
        BackgroundColor3=C.Accent,BackgroundTransparency=0.8,BorderSizePixel=0,
        Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(0.4,0,1,0),
        ZIndex=4,Parent=decFrame})
    Corner(100,purpleLine)
    I("UIGradient",{Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(0,0,0)),
        ColorSequenceKeypoint.new(0.5,C.AccentHi),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(0,0,0)),
    }),Parent=purpleLine})

    Drag(Main,TB)

    -- ── WINDOW BUTTONS  (rielUI-exact sizing + image assets) ─────────
    -- Close: 43x43, red bg on hover, X image rbxassetid://18556800637
    local CloseBtn=I("TextButton",{AnchorPoint=Vector2.new(1,0),
        BackgroundColor3=C.Red,BackgroundTransparency=1,BorderSizePixel=0,
        Position=UDim2.new(1,0,0,0),Size=UDim2.new(0,43,0,43),
        Text="",AutoButtonColor=false,ZIndex=5,Parent=TB})
    Corner(10,CloseBtn)
    -- rielUI uses two invisible frames that turn red on hover for the corner blend
    local cF1=I("Frame",{BackgroundColor3=C.Red,BackgroundTransparency=1,BorderSizePixel=0,
        Size=UDim2.new(0,7,1,0),ZIndex=5,Parent=CloseBtn})
    local cF2=I("Frame",{BackgroundColor3=C.Red,BackgroundTransparency=1,BorderSizePixel=0,
        Position=UDim2.new(0,0,1,-5),Size=UDim2.new(1,0,0,5),ZIndex=5,Parent=CloseBtn})
    I("ImageLabel",{AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,BorderSizePixel=0,
        Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(1,-25,1,-25),
        Image="rbxassetid://18556800637",ImageColor3=C.Text,ZIndex=6,Parent=CloseBtn})
    CloseBtn.MouseEnter:Connect(function()
        CloseBtn.BackgroundTransparency=0; cF1.BackgroundTransparency=0; cF2.BackgroundTransparency=0 end)
    CloseBtn.MouseLeave:Connect(function()
        CloseBtn.BackgroundTransparency=1; cF1.BackgroundTransparency=1; cF2.BackgroundTransparency=1 end)

    -- Max: 43x43, white @ 0.999, slight hover, expand image rbxassetid://9886659406
    local MaxBtn=I("TextButton",{AnchorPoint=Vector2.new(1,0),
        BackgroundColor3=Color3.fromRGB(255,255,255),BackgroundTransparency=0.999,
        BorderSizePixel=0,Position=UDim2.new(1,-43,0,0),Size=UDim2.new(0,43,0,43),
        Text="",AutoButtonColor=false,ZIndex=5,Parent=TB})
    I("ImageLabel",{AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,
        Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(1,-26,1,-26),
        Image="rbxassetid://9886659406",ImageColor3=C.Text,ZIndex=6,Parent=MaxBtn})
    MaxBtn.MouseEnter:Connect(function() TW(MaxBtn,{BackgroundTransparency=0.97},0.1) end)
    MaxBtn.MouseLeave:Connect(function() TW(MaxBtn,{BackgroundTransparency=0.999},0.1) end)

    -- Hide: 43x43, white @ 0.999, hide image rbxassetid://18556824827
    local HideBtn=I("TextButton",{AnchorPoint=Vector2.new(1,0),
        BackgroundColor3=Color3.fromRGB(255,255,255),BackgroundTransparency=0.999,
        BorderSizePixel=0,Position=UDim2.new(1,-86,0,0),Size=UDim2.new(0,43,0,43),
        Text="",AutoButtonColor=false,ZIndex=5,Parent=TB})
    I("ImageLabel",{AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,
        Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(1,-26,1,-26),
        Image="rbxassetid://18556824827",ImageColor3=C.Text,ZIndex=6,Parent=HideBtn})
    HideBtn.MouseEnter:Connect(function() TW(HideBtn,{BackgroundTransparency=0.97},0.1) end)
    HideBtn.MouseLeave:Connect(function() TW(HideBtn,{BackgroundTransparency=0.999},0.1) end)

    -- ── LOGO / SHOW BUTTON  (rielUI showBtn, draggable, 40x40) ───────
    local Logo=I("TextButton",{Name="NexusLogo",
        BackgroundColor3=C.Win,BackgroundTransparency=0.2,BorderSizePixel=0,
        Position=UDim2.new(0,10,0,10),Size=UDim2.new(0,42,0,42),
        Font=Enum.Font.GothamBold,Text=logoText,TextColor3=C.Text,TextSize=15,
        Draggable=true,AutoButtonColor=false,Visible=false,ZIndex=9999,Parent=Gui})
    Corner(10,Logo)
    Stroke(C.Accent,1.5,0.3,Logo)
    -- pulsing purple dot
    local ldot=I("Frame",{BackgroundColor3=C.Accent,BorderSizePixel=0,
        AnchorPoint=Vector2.new(1,1),Position=UDim2.new(1,-2,1,-2),
        Size=UDim2.new(0,8,0,8),ZIndex=10000,Parent=Logo})
    Corner(100,ldot)
    task.spawn(function()
        while Logo.Parent do
            TW(ldot,{Size=UDim2.new(0,10,0,10),BackgroundTransparency=0},0.5)
            task.wait(0.5)
            TW(ldot,{Size=UDim2.new(0,8,0,8),BackgroundTransparency=0.4},0.5)
            task.wait(0.5)
        end
    end)
    Logo.MouseEnter:Connect(function() TW(Logo,{BackgroundTransparency=0},0.12) end)
    Logo.MouseLeave:Connect(function() TW(Logo,{BackgroundTransparency=0.2},0.12) end)
    Logo.MouseButton1Click:Connect(function()
        Logo.Visible=false
        Main.Size=UDim2.new(0,winSize.X.Offset,0,0)
        Main.Visible=true
        TWBack(Main,{Size=winSize},0.45)
    end)

    -- ── BUTTON LOGIC ─────────────────────────────────────
    local function ShowLogo()
        TW(Main,{Size=UDim2.new(0,winSize.X.Offset,0,0),BackgroundTransparency=1},0.25)
        task.wait(0.28)
        Main.Visible=false
        Main.Size=winSize; Main.BackgroundTransparency=C.WinTr
        Logo.Visible=true
    end

    CloseBtn.MouseButton1Click:Connect(ShowLogo)
    HideBtn.MouseButton1Click:Connect(ShowLogo)  -- both close/hide → show logo (rielUI behaviour)

    local maxed,origPos,origSz=false,Main.Position,winSize
    MaxBtn.MouseButton1Click:Connect(function()
        maxed=not maxed
        if maxed then
            origPos=Main.Position; origSz=Main.Size
            TW(Main,{Size=UDim2.new(1,0,1,0)},0.5)
            task.delay(0.1,function() TW(Main,{Position=UDim2.new(0,0,0,0)},0.5) end)
        else
            TW(Main,{Size=origSz},0.5); TW(Main,{Position=origPos},0.5)
        end
    end)

    -- keybind
    UIS.InputBegan:Connect(function(inp,gpe)
        if not gpe and inp.KeyCode==kc then
            if Main.Visible then ShowLogo()
            else Logo.MouseButton1Click:Fire() end
        end
    end)

    -- ── BODY ─────────────────────────────────────────────
    local Body=I("Frame",{BackgroundTransparency=1,BorderSizePixel=0,
        Position=UDim2.new(0,0,0,43),Size=UDim2.new(1,0,1,-43),ZIndex=2,Parent=Main})

    -- ── SIDEBAR  (rielUI: LayersTab — white 0.999, positioned 12px in) ──
    -- rielUI LayersTab: pos (0,12,0,52) size (0,180,1,-64)
    -- We mirror this but make it a real tinted panel
    local SB=I("Frame",{BackgroundColor3=Color3.fromRGB(255,255,255),
        BackgroundTransparency=0.999,BorderSizePixel=0,
        Position=UDim2.new(0,0,0,0),Size=UDim2.new(0,180,1,0),ZIndex=2,Parent=Body})

    -- subtle right border line with purple gradient
    local sbLine=I("Frame",{BackgroundColor3=C.Accent,BackgroundTransparency=0.85,
        BorderSizePixel=0,Position=UDim2.new(1,0,0,0),
        Size=UDim2.new(0,1,1,0),ZIndex=3,Parent=SB})
    I("UIGradient",{Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(0,0,0)),
        ColorSequenceKeypoint.new(0.3,C.AccentHi),
        ColorSequenceKeypoint.new(0.7,C.Accent),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(0,0,0)),
    }),Rotation=90,Parent=sbLine})

    -- tab scroll (rielUI ScrollTab: pos y=95, leaves room for Info + SearchFrame)
