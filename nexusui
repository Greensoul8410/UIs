        Position=UDim2.new(0,0,0,0),Size=UDim2.new(1,0,1,-68),
        ScrollBarThickness=0,ZIndex=3,Parent=SB})
    Pad(6,6,4,6,TScroll)
    local TList=List(Enum.FillDirection.Vertical,Enum.HorizontalAlignment.Left,2,TScroll)
    AutoCanvas(TList,TScroll,8)

    -- ── PLAYER INFO CARD  (rielUI Info panel style) ──────
    -- rielUI Info: pos (0,52,0,14) for name, (0,52,0,25) for description, logo 40x40
    local PC=I("Frame",{Name="PlayerCard",AnchorPoint=Vector2.new(0,1),
        BackgroundColor3=Color3.fromRGB(255,255,255),BackgroundTransparency=0.97,
        BorderSizePixel=0,Position=UDim2.new(0,0,1,0),Size=UDim2.new(1,0,0,68),
        ZIndex=3,Parent=SB})
    Corner(4,PC)
    -- top separator
    I("Frame",{BackgroundColor3=C.DecideLine,BackgroundTransparency=C.DecideTr,
        BorderSizePixel=0,Size=UDim2.new(1,0,0,1),ZIndex=4,Parent=PC})

    -- avatar frame (rielUI LogoFrame: white 0.95, 40x40, rounded)
    local avF=I("Frame",{AnchorPoint=Vector2.new(0,0.5),
        BackgroundColor3=Color3.fromRGB(255,255,255),BackgroundTransparency=0.95,
        BorderSizePixel=0,Position=UDim2.new(0,4,0.5,0),
        Size=UDim2.new(0,42,0,42),ZIndex=4,Parent=PC})
    Corner(1000,avF)
    Stroke(Color3.fromRGB(255,255,255),2,0.95,avF)  -- rielUI UIStroke on LogoFrame
    local avImg=I("ImageLabel",{AnchorPoint=Vector2.new(0.5,0.5),BackgroundTransparency=1,
        BorderSizePixel=0,Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(1,0,1,0),
        Image="",ZIndex=5,Parent=avF})
    Corner(1000,avImg)
    -- online dot
    local onDot=I("Frame",{AnchorPoint=Vector2.new(1,1),BackgroundColor3=C.Green,
        BorderSizePixel=0,Position=UDim2.new(1,-1,1,-1),Size=UDim2.new(0,9,0,9),ZIndex=6,Parent=avF})
    Corner(100,onDot)
    Stroke(C.Win,1.5,0,onDot)
    -- load avatar thumbnail async
    task.spawn(function()
        local ok,uid=pcall(function() return PLS:GetUserIdFromNameAsync(LP.Name) end)
        if ok then
            local ok2,th=pcall(function()
                return PLS:GetUserThumbnailAsync(uid,Enum.ThumbnailType.HeadShot,Enum.ThumbnailSize.Size60x60)
            end)
            if ok2 then avImg.Image=th end
        end
    end)
