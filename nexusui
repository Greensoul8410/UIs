========================================================
USAGE EXAMPLE
========================================================

local UI = loadstring(game:HttpGet("YOUR_RAW_URL"))()

local win = UI:Window({
    Title = "Darksoul Hub",
    Description = "v1.0",
    Size = UDim2.new(0, 620, 0, 440),
    KeyCode = Enum.KeyCode.RightControl,
})

local tab = win:AddTab({
    Title = "Combat",
    Icon = "rbxassetid://10709791437",   -- provide your own asset id
})

-- Redz-style flat section divider
local sec = tab:AddSection({ Title = "Aimbot", Icon = "rbxassetid://10734943674" })

-- Add items to section (they live in the same scroll list, below the divider)
sec:AddToggle("Out", {
    Title = "Silent Aim",
    Description = "Locks onto nearest target",
    Default = false,
    Callback = function(v) print("Silent Aim:", v) end
})

sec:AddButton("Out", {
    Title = "Teleport to Ball",
    ClickName = "Execute",
    Callback = function() print("Teleported!") end
})

-- Notification (Redz-style slide-in toast)
win:Notify({
    Title = "Darksoul Hub",
    Content = "Script loaded successfully!",
    Icon = "rbxassetid://10709791437",
    Duration = 5,
})

========================================================
CHANGES SUMMARY
========================================================
[1] SCROLLABLE TABS
    - ScrollTab now uses AutomaticCanvasSize = Y
    - Scroll bar visible (blue, 3px) when tabs overflow
    - No need to drag-resize the window to see hidden tabs

[2] DRAG POSITION SAVED IN-MEMORY
    - SavedWindowPosition updated on every drag end
    - Window reopens at last known position (session only)
    - ShowButton also uses proper MakeDraggable

[3] REDZ-STYLE NOTIFICATIONS
    - win:Notify({ Title, Content, Icon, Duration })
    - Slides in from right, timed progress bar at bottom
    - Click to dismiss early
    - Stacks vertically (multiple at once)
    - Accent bar on left side

[4] REDZ-STYLE SECTIONS (flat dividers)
    - tab:AddSection({ Title, Icon }) returns InSec API
    - InSec:AddToggle / InSec:AddButton work as before
    - Flat label + horizontal line (no expandable panel)
    - Optional icon next to section label

[5] BUG FIXES
    - HideButton declared only once (was duplicated)
    - CloseButton click event registered only once (was duplicated)
    - DecideFrame UICorner parented to DecideFrame (was wrong)
    - ScrollTab uses AutomaticCanvasSize (no manual CanvasSize needed)
    - ShowButton uses MakeDraggable (was using deprecated .Draggable)
    - AddSecion typo kept as alias for backward compatibility
]]
