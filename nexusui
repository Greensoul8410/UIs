--[[
    NexusUI v3.0
    URL: https://raw.githubusercontent.com/Greensoul8410/UIs/refs/heads/main/nexusui

    Exactly rielUI's visual shell (RGB(30,30,30) @ 0.15, UIStroke 2.6,
    transparent top, real image-based window buttons) fused with
    redz v5's clean Tab/Section/Element API + purple accents.

    API:
        local Nexus  = loadstring(game:HttpGet("..."))()
        local Window = Nexus:Window({ Title, Description, KeyCode, Size, LogoText })
        local Tab    = Window:AddTab({ Title, Icon })
        local Sec    = Tab:AddSection({ Title, Description })
        Sec:AddToggle    ({ Title, Description, Default, Callback })
        Sec:AddButton    ({ Title, Description, ClickName, Callback })
        Sec:AddSlider    ({ Title, Description, Min, Max, Default, Increment, Callback })
        Sec:AddDropdown  ({ Title, Description, Values, Default, Multi, Callback })
        Sec:AddParagraph ({ Title, Content })
        Sec:AddInput     ({ Title, Description, Placeholder, Callback })
        Sec:AddDiscordInvite({ Title, Description, Link, Callback })
        Window:Notify    ({ Title, Description, Duration, Type })
]]

