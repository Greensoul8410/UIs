            function SectionObj:AddSlider(scfg)
                scfg = scfg or {}
                local sTitle     = scfg.Title       or "Slider"
                local sDesc      = scfg.Description or ""
                local sMin       = scfg.Min         or 0
                local sMax       = scfg.Max         or 100
                local sDefault   = scfg.Default     or sMin
                local sIncrement = scfg.Increment   or 1
                local sCb        = scfg.Callback    or function() end

                local row = BaseRow(54)
                RowLabels(row, sTitle, sDesc)

                local valDisplay = New("TextLabel", {
                    AnchorPoint = Vector2.new(1, 0),
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -12, 0, 8),
                    Size = UDim2.new(0, 50, 0, 14),
                    Font = Enum.Font.GothamBold,
                    Text = tostring(sDefault),
                    TextColor3 = theme.Accent,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    ZIndex = 5,
                    Parent = row,
                })

                local TrackBg = New("Frame", {
                    BackgroundColor3 = theme.SurfaceTop,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 12, 1, -16),
                    Size = UDim2.new(1, -24, 0, 5),
                    ZIndex = 5,
                    Parent = row,
                })
                Corner(4, TrackBg)

                local TrackFill = New("Frame", {
                    BackgroundColor3 = theme.Accent,
                    BorderSizePixel = 0,
                    Size = UDim2.new(0, 0, 1, 0),
                    ZIndex = 6,
                    Parent = TrackBg,
                })
                Corner(4, TrackFill)
                New("UIGradient", {
                    Color = ColorSequence.new(theme.AccentGlow, theme.Accent),
                    Parent = TrackFill,
                })

                local Handle = New("Frame", {
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    BackgroundColor3 = Color3.fromRGB(255,255,255),
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0.5, 0),
                    Size = UDim2.new(0, 13, 0, 13),
                    ZIndex = 7,
                    Parent = TrackBg,
                })
                Corner(100, Handle)
                New("UIStroke", { Color = theme.Accent, Thickness = 2, Parent = Handle })

                local currentValue = sDefault
                local function SetValue(val, silent)
                    val = math.clamp(math.round(val / sIncrement) * sIncrement, sMin, sMax)
                    currentValue = val
                    local pct = (val - sMin) / (sMax - sMin)
                    Tween(TrackFill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.1)
                    Tween(Handle, { Position = UDim2.new(pct, 0, 0.5, 0) }, 0.1)
                    valDisplay.Text = tostring(val)
                    if not silent then sCb(val) end
                end

                SetValue(sDefault, true)

                local sliding = false
                local SliderBtn = New("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    ZIndex = 8,
                    Parent = TrackBg,
                })

                SliderBtn.MouseButton1Down:Connect(function()
                    sliding = true
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = false
                    end
                end)
                RunService.RenderStepped:Connect(function()
                    if sliding then
                        local abs = TrackBg.AbsolutePosition
                        local sz  = TrackBg.AbsoluteSize
                        local mx  = Mouse.X
                        local pct = math.clamp((mx - abs.X) / sz.X, 0, 1)
                        SetValue(sMin + (sMax - sMin) * pct)
                    end
                end)

                return { Set = SetValue, Get = function() return currentValue end }
            end

            -- ══════════════════════════════════════════════
            --  DROPDOWN
            -- ══════════════════════════════════════════════
            function SectionObj:AddDropdown(dcfg)
                dcfg = dcfg or {}
                local dTitle   = dcfg.Title    or "Dropdown"
                local dDesc    = dcfg.Description or ""
                local dValues  = dcfg.Values   or {}
                local dDefault = dcfg.Default  or (dValues[1] and {dValues[1]} or {})
                local dMulti   = dcfg.Multi    or false
                local dCb      = dcfg.Callback or function() end

                if type(dDefault) == "string" then dDefault = {dDefault} end

                local selected = {}
                for _, v in ipairs(dDefault) do selected[v] = true end

                local row = BaseRow(46)
                RowLabels(row, dTitle, dDesc)

                local function GetSelectedText()
                    local keys = {}
                    for k in pairs(selected) do table.insert(keys, k) end
                    if #keys == 0 then return "None" end
                    if #keys == 1 then return keys[1] end
                    return keys[1] .. " +" .. (#keys - 1)
                end

                local DropBtn = New("TextButton", {
                    AnchorPoint = Vector2.new(1, 0.5),
                    BackgroundColor3 = theme.SurfaceTop,
                    BorderSizePixel = 0,
                    Position = UDim2.new(1, -12, 0.5, 0),
                    Size = UDim2.new(0, 120, 0, 26),
                    Font = Enum.Font.Gotham,
                    Text = GetSelectedText(),
                    TextColor3 = theme.TextMuted,
                    TextSize = 11,
                    AutoButtonColor = false,
                    ZIndex = 5,
                    Parent = row,
                })
                Corner(6, DropBtn)
                Stroke(theme.Border, 1, 0, DropBtn)
                Padding(0, 20, 0, 8, DropBtn)

                -- arrow
                New("TextLabel", {
                    AnchorPoint = Vector2.new(1, 0.5),
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -6, 0.5, 0),
                    Size = UDim2.new(0, 14, 0, 14),
                    Font = Enum.Font.GothamBold,
                    Text = "▾",
                    TextColor3 = theme.TextDim,
                    TextSize = 11,
                    ZIndex = 6,
                    Parent = DropBtn,
                })

                -- dropdown panel (created on open)
                local open = false
                local DropPanel

                local function ClosePanel()
                    if DropPanel then
                        Tween(DropPanel, { BackgroundTransparency = 1 }, 0.15)
                        task.delay(0.15, function()
                            if DropPanel then DropPanel:Destroy(); DropPanel = nil end
                        end)
                    end
                    open = false
                end

                local function OpenPanel()
                    if DropPanel then ClosePanel(); return end
                    open = true

                    local panelHeight = math.min(#dValues * 28 + 8, 160)
                    DropPanel = New("Frame", {
                        BackgroundColor3 = theme.Surface,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, DropBtn.AbsolutePosition.X - row.AbsolutePosition.X,
                                             0, row.Size.Y.Offset + 2),
                        Size = UDim2.new(0, 120, 0, panelHeight),
                        ZIndex = 20,
                        Parent = SectionFrame,
                    })
                    Corner(6, DropPanel)
                    Stroke(theme.Accent, 1, 0.5, DropPanel)
                    AddShadow(DropPanel, 16, 0.6)

                    local PanelScroll = New("ScrollingFrame", {
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 1, 0),
                        ScrollBarThickness = 2,
                        ScrollBarImageColor3 = theme.Accent,
                        CanvasSize = UDim2.new(0, 0, 0, #dValues * 28 + 8),
                        ZIndex = 21,
                        Parent = DropPanel,
                    })
                    Padding(4, 4, 4, 4, PanelScroll)
                    ListLayout(Enum.FillDirection.Vertical, Enum.HorizontalAlignment.Left, 2, PanelScroll)

                    for _, val in ipairs(dValues) do
                        local isSelected = selected[val] == true
                        local Item = New("TextButton", {
                            BackgroundColor3 = isSelected and theme.Accent or theme.SurfaceHigh,
                            BackgroundTransparency = isSelected and 0.7 or 0,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 0, 0, 24),
                            Font = Enum.Font.Gotham,
                            Text = val,
                            TextColor3 = isSelected and theme.Accent or theme.TextMuted,
                            TextSize = 11,
                            AutoButtonColor = false,
                            ZIndex = 22,
                            Parent = PanelScroll,
                        })
                        Corner(4, Item)

                        Item.MouseEnter:Connect(function()
                            if not selected[val] then
                                Tween(Item, { BackgroundTransparency = 0.85, TextColor3 = theme.Text }, 0.12)
                            end
                        end)
                        Item.MouseLeave:Connect(function()
                            if not selected[val] then
                                Tween(Item, { BackgroundTransparency = 0, TextColor3 = theme.TextMuted }, 0.12)
                            end
                        end)

                        Item.MouseButton1Click:Connect(function()
                            if dMulti then
                                selected[val] = not selected[val] or nil
                            else
                                selected = {}
                                selected[val] = true
                                ClosePanel()
                            end
                            DropBtn.Text = GetSelectedText()
                            local keys = {}
                            for k in pairs(selected) do table.insert(keys, k) end
                            dCb(dMulti and keys or keys[1])
                        end)
                    end

                    DropPanel.BackgroundTransparency = 1
                    Tween(DropPanel, { BackgroundTransparency = 0 }, 0.15)
                end

                DropBtn.MouseButton1Click:Connect(OpenPanel)

                -- close on outside click
                UserInputService.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 and open then
                        if DropPanel and not DropPanel.AbsolutePosition.X <= Mouse.X then
                            ClosePanel()
                        end
                    end
                end)

                return {
                    Set = function(_, val)
                        selected = {}
                        if type(val) == "table" then
                            for _, v in ipairs(val) do selected[v] = true end
                        else
                            selected[val] = true
                        end
                        DropBtn.Text = GetSelectedText()
                    end,
                    Get = function()
                        local keys = {}
                        for k in pairs(selected) do table.insert(keys, k) end
                        return dMulti and keys or keys[1]
                    end
                }
            end

